# Shared config for mistral_toolid_proxy.
# Use with Docker (`docker run --env-file mistral-toolid-proxy.env ...`) or
# systemd (copy to /etc/mistral-toolid-proxy.env, mode 0600).

# Where your Mistral endpoint actually listens — local vLLM or a public API.
UPSTREAM=http://127.0.0.1:8001

# Proxy listen address/port.
HOST=0.0.0.0
PORT=8081

# Optional. If set, the proxy injects this as `Authorization: Bearer <API_KEY>`
# toward the upstream, so local clients can stay keyless. Leave unset/commented
# to pass the client's own Authorization header straight through.
#API_KEY=sk-your-mistral-key
